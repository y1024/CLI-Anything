# Step 7: Ignore build artifacts within allowed dirs
**/__pycache__/
**/*.egg-info/
**/*.pyc
**/dist/
**/build/
**/.pytest_cache/
**/*.egg
**/*.wav
**/*.blend
**/*.xcf
**/*.mlt

# Step 8: But allow assets images
!/assets/*.png
!/assets/*.jpg

assets/gen_typing_gif.py
!README_CN.md
!opencode-commands/
!/qoder-plugin/

# Step 10: Allow CLI Hub registry and frontend
!/registry.json
!/public_registry.json
!/matrix_registry.json
!/docs/
/docs/*
!/docs/PREVIEW_PROTOCOL.md
!/docs/PREVIEW_PROGRESS.md
!/docs/FREECAD_VIDEO_REFERENCE.md
!/docs/PREVIEW_MECHANISM_PROGRESS.md
!/docs/scripts/
